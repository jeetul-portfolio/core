{
  "general": {
    "namespace": "portfolio",
    "preStartImage": "busybox:1.36",
    "resources": {
      "requests": {
        "cpu": "100m",
        "memory": "128Mi"
      },
      "limits": {
        "cpu": "250m",
        "memory": "256Mi"
      }
    }
  },
  "deployments": [
    {
      "name": "core",
      "replicas": 1,
      "image": "docker.io/jeetulsamaiya1/portfolio:core-master-1021",
      "containerPort": 8080,
      "preStartCommands": [
        "echo Preparing app before startup",
        "echo Pre-start checks completed"
      ],
      "service": {
        "type": "ClusterIP",
        "port": 8080,
        "targetPort": 8080
      },
      "configMounts": []
    }
  ]
}
